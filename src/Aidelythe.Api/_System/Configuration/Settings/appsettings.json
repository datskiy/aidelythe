{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AccessToken": {
    "Issuer": "Aidelythe",
    "Audience": "Aidelythe",
    "SigningKey": "__SECRET__",
    "ExpiresInSeconds": 1200,
    "ClockSkewInSeconds": 30
  },
  "RefreshToken": {
    "ByteCount": 64,
    "ExpiresInSeconds": 1209600
  },
  "RateLimiting": {
    "AnonymousPermitLimit": 10,
    "AuthenticatedPermitLimit": 30,
    "WindowSizeInSeconds": 60
  }
}