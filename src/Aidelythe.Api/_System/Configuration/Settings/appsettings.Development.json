{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug"
    },
    "WriteTo": [{
      "Name": "Async",
      "Args": {
        "configure": [{
          "Name": "Console",
          "Args": {
            "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
          }
        }]
      }
    }],
    "Enrich": [ "FromLogContext", "WithThreadId" ]
  },
  "AccessToken": {
    "ExpiresInSeconds": 3600
  },
  "RateLimiting": {
    "AnonymousPermitLimit": 1000,
    "AuthenticatedPermitLimit": 1000
  }
}